  #rk-fbt-{{ section.id }} * { box-sizing: border-box; }

  #rk-fbt-{{ section.id }} .rk-fbt__inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  #rk-fbt-{{ section.id }} .rk-fbt__title {
    font-family: var(--rk-font-display);
    font-weight: 600;
    font-size: clamp(20px, 2.2vw, 28px);
    margin: 0 0 24px;
    color: var(--rk-ink);
