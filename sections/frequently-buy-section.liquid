    --rk-ink: #241811;
    --rk-ink-soft: #5B4A3C;
    --rk-brown: #3B2415;
    --rk-gold: #C99A3D;
    --rk-red: #9C2E27;
    --rk-green: #2F5233;
    --rk-green-dark: #223F26;
    --rk-line: #E4D9C6;
    --rk-card-bg: #FFFFFF;
    --rk-font-display: 'Poppins', -apple-system, sans-serif;
    --rk-font-body: 'Jost', -apple-system, sans-serif;

    background: var(--rk-bg);
    color: var(--rk-ink);
    font-family: var(--rk-font-body);
    padding: clamp(28px, 4vw, 56px) clamp(16px, 5vw, 56px);
