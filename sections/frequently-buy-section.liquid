{%- comment -%}
  Section: Frequently Bought Together (Raja Maharaja style) + Combo Discount
  Add one product block per item. Shoppers can uncheck items they don't
  want; the total price, savings, and "Add selected" button update live.
  An optional combo discount (percentage or fixed) can be applied on top
  of the selected items' price, either always or only when every item in
  the bundle is selected. No metafield setup required — products are
  picked directly in the theme editor via section blocks.
{%- endcomment -%}

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@500;600;700&family=Jost:wght@400;500;600&display=swap" rel="stylesheet">

{%- assign rk_fbt_count = 0 -%}
{%- for block in section.blocks -%}
  {%- if block.type == 'product' and block.settings.product != blank -%}
    {%- assign rk_fbt_count = rk_fbt_count | plus: 1 -%}
  {%- endif -%}
{%- endfor -%}

<section class="rk-fbt" id="rk-fbt-{{ section.id }}" data-count="{{ rk_fbt_count }}">
  <div class="rk-fbt__inner">

    {%- if section.settings.title != blank -%}
      <h2 class="rk-fbt__title">{{ section.settings.title }}</h2>
    {%- endif -%}

    {%- comment -%} Build a display string for the discount badge, e.g. "10%" or "$5.00" {%- endcomment -%}
    {%- assign rk_discount_type = section.settings.discount_type -%}
    {%- assign rk_discount_value = section.settings.discount_value -%}
    {%- assign rk_show_badge = false -%}
    {%- if rk_discount_type != 'none' and rk_discount_value > 0 -%}
      {%- assign rk_show_badge = true -%}
      {%- if rk_discount_type == 'percentage' -%}
        {%- assign rk_discount_display = rk_discount_value | append: '%' -%}
      {%- else -%}
        {%- assign rk_discount_cents = rk_discount_value | times: 100 -%}
        {%- assign rk_discount_display = rk_discount_cents | money -%}
      {%- endif -%}
      {%- assign rk_badge_text = section.settings.discount_badge_text | replace: '{discount}', rk_discount_display -%}
    {%- endif -%}

    {%- if rk_fbt_count == 0 -%}
      <div class="rk-fbt__empty">Add product blocks in the theme editor to build this bundle.</div>
    {%- else -%}

      <div class="rk-fbt__layout">

        <div class="rk-fbt__items">
          {%- assign rk_i = 0 -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'product' -%}
              {%- assign p = block.settings.product -%}
              {%- if p != blank -%}
                {%- assign rk_i = rk_i | plus: 1 -%}
                {%- assign v = p.selected_or_first_available_variant -%}

                <div
                  class="rk-fbt__card rk-fbt__capsule"
                  data-rk-fbt-card
                  {{ block.shopify_attributes }}
                >
                  <label class="rk-fbt__check-label">
                    <input
                      type="checkbox"
                      class="rk-fbt__checkbox"
                      data-rk-fbt-checkbox
                      {% if v.available == false %}disabled{% else %}checked{% endif %}
                    >
                    <span class="rk-fbt__check" aria-hidden="true"></span>
                  </label>

                  {%- if p.featured_image != blank -%}
                    <div class="rk-fbt__avatar">
                      <img
                        src="{{ p.featured_image | image_url: width: 120 }}"
                        alt="{{ p.title }}"
                        loading="lazy"
                      >
                    </div>
                  {%- else -%}
                    <div class="rk-fbt__avatar rk-fbt__avatar--placeholder">
                      {{ 'image' | placeholder_svg_tag: 'rk-placeholder' }}
                    </div>
                  {%- endif -%}

                  <div class="rk-fbt__card-info">
                    <p class="rk-fbt__name">{{ p.title }}</p>

                    <p class="rk-fbt__price">
                      {%- if v.compare_at_price > v.price -%}
                        <span class="rk-fbt__compare">{{ v.compare_at_price | money }}</span>
                      {%- endif -%}
                      <span class="rk-fbt__current">{{ v.price | money }}</span>
                    </p>

                    {%- unless v.available -%}
                      <span class="rk-pill rk-pill--soldout rk-fbt__soldout">Sold out</span>
                    {%- endunless -%}
                  </div>

                  <div class="rk-fbt__card-action">
                    {%- if p.has_only_default_variant -%}
                      <input type="hidden" data-rk-fbt-variant-id value="{{ v.id }}" data-price="{{ v.price }}" data-compare="{{ v.compare_at_price }}">
                    {%- else -%}
                      <select class="rk-fbt__select" data-rk-fbt-variant-select>
                        {%- for variant in p.variants -%}
                          <option
                            value="{{ variant.id }}"
                            data-price="{{ variant.price }}"
                            data-compare="{{ variant.compare_at_price }}"
                            {% if variant == v %}selected{% endif %}
                            {% unless variant.available %}disabled{% endunless %}
                          >
                            {{ variant.title }}{% unless variant.available %} — Sold out{% endunless %}
                          </option>
                        {%- endfor -%}
                      </select>
                    {%- endif -%}
                  </div>
                </div>
              {%- endif -%}
            {%- endif -%}
          {%- endfor -%}
        </div>

        <div class="rk-fbt__summary">
          {%- if rk_show_badge -%}
            <p class="rk-fbt__badge">{{ rk_badge_text }}</p>
          {%- endif -%}
          <p class="rk-fbt__summary-label">Total price</p>
          <div class="rk-fbt__summary-price">
            <span class="rk-fbt__summary-compare" data-rk-fbt-total-compare></span>
            <span class="rk-fbt__summary-current" data-rk-fbt-total-current></span>
          </div>
          <p class="rk-fbt__summary-save" data-rk-fbt-save></p>
          <p class="rk-fbt__summary-hint" data-rk-fbt-discount-hint></p>
          <button type="button" class="rk-btn rk-btn--primary rk-fbt__add-btn" data-rk-fbt-add>
            {{ section.settings.button_label }}
          </button>
          <p class="rk-fbt__summary-note" data-rk-fbt-note></p>
        </div>

      </div>
    {%- endif -%}

  </div>
</section>

<style>
