{%- if rk_fbt_count > 0 -%}
<script>
  (function () {
    var root = document.getElementById('rk-fbt-{{ section.id }}');
    if (!root) return;

    var currencyCode = {{ cart.currency.iso_code | json }};
    var locale = {{ request.locale.iso_code | default: 'en-IN' | json }};

    // Combo discount config, set in the theme editor
    var discountType = {{ section.settings.discount_type | json }};       // 'none' | 'percentage' | 'fixed'
    var discountValue = parseFloat({{ section.settings.discount_value | json }}) || 0;
    var requireAllItems = {{ section.settings.require_all_items | json }};
    var totalBlockCount = {{ rk_fbt_count | json }};
    var discountDisplay = {{ rk_discount_display | default: '' | json }};

    function formatMoney(cents) {
      try {
        return new Intl.NumberFormat(locale, { style: 'currency', currency: currencyCode, minimumFractionDigits: 2 }).format(cents / 100);
      } catch (e) {
        return (cents / 100).toFixed(2);
      }
    }

    var cards = Array.prototype.slice.call(root.querySelectorAll('[data-rk-fbt-card]'));
    var totalCurrentEl = root.querySelector('[data-rk-fbt-total-current]');
    var totalCompareEl = root.querySelector('[data-rk-fbt-total-compare]');
    var saveEl = root.querySelector('[data-rk-fbt-save]');
    var hintEl = root.querySelector('[data-rk-fbt-discount-hint]');
    var addBtn = root.querySelector('[data-rk-fbt-add]');
    var noteEl = root.querySelector('[data-rk-fbt-note]');

    function getCardPricing(card) {
      var select = card.querySelector('[data-rk-fbt-variant-select]');
      var hidden = card.querySelector('[data-rk-fbt-variant-id]');
      if (select) {
        var opt = select.options[select.selectedIndex];
        return {
          id: select.value,
          price: parseInt(opt.getAttribute('data-price'), 10) || 0,
          compare: parseInt(opt.getAttribute('data-compare'), 10) || 0
        };
      }
      if (hidden) {
        return {
          id: hidden.value,
          price: parseInt(hidden.getAttribute('data-price'), 10) || 0,
          compare: parseInt(hidden.getAttribute('data-compare'), 10) || 0
        };
      }
      return { id: null, price: 0, compare: 0 };
    }

    function recalc() {
      var total = 0;
      var totalCompare = 0;
      var anyChecked = false;
      var checkedCount = 0;

      cards.forEach(function (card) {
        var checkbox = card.querySelector('[data-rk-fbt-checkbox]');
        if (checkbox && checkbox.checked) {
          anyChecked = true;
          checkedCount += 1;
          var pricing = getCardPricing(card);
          total += pricing.price;
          totalCompare += pricing.compare > pricing.price ? pricing.compare : pricing.price;
        }
      });

      // Work out whether the combo discount applies to the current selection
      var discountEligible = discountType !== 'none' && discountValue > 0 && anyChecked &&
        (!requireAllItems || checkedCount === totalBlockCount);

      var discountAmount = 0;
      if (discountEligible) {
        if (discountType === 'percentage') {
          discountAmount = Math.round(total * (discountValue / 100));
        } else if (discountType === 'fixed') {
          discountAmount = Math.round(discountValue * 100);
        }
        discountAmount = Math.min(discountAmount, total);
      }

      var finalTotal = total - discountAmount;

      if (totalCurrentEl) totalCurrentEl.textContent = formatMoney(finalTotal);
      if (totalCompareEl) {
        if (totalCompare > finalTotal) {
          totalCompareEl.textContent = formatMoney(totalCompare);
          totalCompareEl.style.display = '';
        } else {
          totalCompareEl.style.display = 'none';
        }
      }
      if (saveEl) {
        var savings = totalCompare - finalTotal;
        saveEl.textContent = savings > 0 ? 'You save ' + formatMoney(savings) : '';
      }
      if (hintEl) {
        if (requireAllItems && discountType !== 'none' && discountValue > 0 && anyChecked && checkedCount < totalBlockCount) {
          hintEl.textContent = 'Select all ' + totalBlockCount + ' items to unlock ' + discountDisplay + ' off';
        } else {
          hintEl.textContent = '';
        }
      }
      if (addBtn) addBtn.disabled = !anyChecked;
    }

    cards.forEach(function (card) {
      var checkbox = card.querySelector('[data-rk-fbt-checkbox]');
      var select = card.querySelector('[data-rk-fbt-variant-select]');
      checkbox && checkbox.addEventListener('change', recalc);
      select && select.addEventListener('change', recalc);
    });

    recalc();

    addBtn && addBtn.addEventListener('click', function () {
      var items = [];
      cards.forEach(function (card) {
        var checkbox = card.querySelector('[data-rk-fbt-checkbox]');
        if (checkbox && checkbox.checked) {
          var pricing = getCardPricing(card);
          if (pricing.id) items.push({ id: pricing.id, quantity: 1 });
        }
      });

      if (!items.length) return;

      addBtn.disabled = true;
      var originalText = addBtn.textContent;
      addBtn.textContent = 'Adding...';

      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ items: items })
      })
        .then(function (res) {
          if (!res.ok) throw new Error('Add to cart failed');
          return res.json();
        })
        .then(function () {
          window.location.href = '/cart';
        })
        .catch(function () {
          addBtn.disabled = false;
          addBtn.textContent = originalText;
          if (noteEl) noteEl.textContent = 'Something went wrong. Please try again.';
        });
    });
  })();
</script>
{%- endif -%}

{% schema %}
{
  "name": "Frequently Bought",
  "settings": [
    { "type": "text", "id": "title", "label": "Title", "default": "Frequently Bought Together" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Add selected to cart" },
    {
      "type": "select",
      "id": "discount_type",
      "label": "Combo discount type",
      "options": [
        { "value": "none", "label": "No extra discount" },
        { "value": "percentage", "label": "Percentage off" },
        { "value": "fixed", "label": "Fixed amount off" }
      ],
      "default": "none",
      "info": "Applies on top of each product's own price/compare-at price."
    },
    {
      "type": "number",
      "id": "discount_value",
      "label": "Discount value",
      "default": 0,
      "info": "Enter a percentage (e.g. 10) or a fixed amount in your store currency (e.g. 5.00), matching the type above."
    },
    {
      "type": "checkbox",
      "id": "require_all_items",
      "label": "Only apply discount when every item is selected",
      "default": false
    },
    {
      "type": "text",
      "id": "discount_badge_text",
      "label": "Combo badge text",
      "default": "Combo Offer – Extra {discount} off",
      "info": "Use {discount} as a placeholder, e.g. 'Save {discount} extra!'"
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [
        { "type": "product", "id": "product", "label": "Product" }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    { "name": "Frequently Bought" }
  ]
}
{% endschema %}
