  #rk-fbt-{{ section.id }} .rk-fbt__layout {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 32px;
    align-items: start;
  }

  /* ---- Formula Chain Items ---- */
  #rk-fbt-{{ section.id }} .rk-fbt__items {
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
    width: 100%;
    gap: 20px;
    padding: 10px 0;
